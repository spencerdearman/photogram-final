<!DOCTYPE html>
<html>
  <head>
    <title>Photogram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
  </head>

  <body>
    <ul>
      <li><a href="/users">All users</a></li>
      <li><a href="/photos">All public photos</a></li>

      <% if user_signed_in? %>
        <li>Welcome, <%= current_user.email %>!</li>
        <li><a href="/users/edit"><%= current_user.username %></a></li>
        <li><a href="/users/sign_out" data-method="delete" rel="nofollow">Sign out</a></li>
      <% else %>
        <li><a href="/users/sign_in">Sign in</a></li>
        <li><a href="/users/sign_up">Sign up</a></li>
      <% end %>
    </ul>

    <%= yield %>
  </body>
</html>
