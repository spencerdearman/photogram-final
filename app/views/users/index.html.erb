<!DOCTYPE html>
<html>
<head>
  <title>Target: Photogram Final</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <h1>List of users</h1>

  <table border="1">
    <thead>
      <tr>
        <th>Username</th>
        <th>Private?</th>
        <th>Follow</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.username %></td>
          <td><%= user.private ? 'Yes' : 'No' %></td>
          <td>
            <form action="/insert_follow_request" method="post">
              <input type="hidden" name="query_recipient_id" value="<%= user.id %>">
              <button>Follow</button>
            </form>
          </td>
          <td>
            <a href="/users/<%= user.id %>">Show details</a>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

</body>
</html>
